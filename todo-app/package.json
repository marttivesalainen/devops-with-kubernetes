{
	"name": "todo-app",
	"version": "1.0.0",
	"description": "This project was bootstrapped with Fastify-CLI.",
	"type": "module",
	"engine": {
		"node": "24.18.0"
	},
	"scripts": {
		"dev": "tsx watch --env-file=.env ./app/index.ts",
		"build": "npm run build:clean && npm run build:tsc",
		"build:clean": "rm -rf ./build",
		"build:tsc": "tsc --project tsconfig.build.json",
		"start": "node ./build/app/index.js",
		"format": "biome check . --config-path ./biome.jsonc --linter-enabled=false",
		"format:fix": "biome check . --config-path ./biome.jsonc --linter-enabled=false --write",
		"format:ci": "biome ci . --config-path ./biome.jsonc --linter-enabled=false",
		"lint": "npm run lint:biome",
		"lint:fix": "npm run lint:biome:fix",
		"lint:ci": "npm run lint:biome:ci",
		"lint:biome": "biome lint . --config-path ./biome.jsonc",
		"lint:biome:fix": "biome lint . --config-path ./biome.jsonc --write",
		"lint:biome:ci": "biome ci . --config-path ./biome.jsonc --formatter-enabled=false --assist-enabled=false",
		"types": "tsc --noEmit"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@fastify/autoload": "^6.0.0",
		"@fastify/sensible": "^6.0.0",
		"fastify": "^5.0.0",
		"fastify-cli": "^8.0.0",
		"fastify-type-provider-zod": "^7.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.5",
		"@tsconfig/node24": "^24.0.4",
		"@tsconfig/strictest": "^2.0.8",
		"@types/node": "^26.1.1",
		"fastify-tsconfig": "^3.0.0",
		"tsx": "^4.23.1",
		"typescript": "^7.0.2"
	}
}
