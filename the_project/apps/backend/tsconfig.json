{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": [
		"../../tsconfig.json",
		"@tsconfig/node24/tsconfig.json"
	],
	"compilerOptions": {
		"lib": ["ES2023"],
		"outDir": "./build",
		"rootDir": ".",
		"sourceMap": true,
		"stripInternal": true,
		"paths": {
			"~/*": ["./*"]
		}
	},
	"include": ["**/*.ts"],
	"exclude": ["build", "node_modules"]
}
